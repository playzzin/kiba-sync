# planning-harness 플러그인을 다른 프로젝트에서 쓸 때의 프로젝트별 설정.
#
# 사용법: 이 파일을 대상 프로젝트 루트의  .harness/config.env  로 복사하고 값을 채운다.
#   mkdir -p .harness && cp <플러그인>/templates/harness.config.env .harness/config.env
#
# 여기 값이 플러그인 기본 scripts/config.env 를 덮어쓴다(환경변수가 있으면 그게 최우선).
# 값에 공백이 있으면 반드시 따옴표로 감쌀 것.

OWNER="your-org-or-username"          # GitHub 사용자/조직 로그인
PROJECT_NUMBER="1"                    # Project V2 번호
REPO="your-org/your-repo"             # 이슈를 생성할 repo (owner/name)
PROJECT_TITLE="프로젝트 보드"          # 보고용 표시 이름
DEFAULT_LABELS="from-meeting,todo"    # 새 이슈 기본 라벨
