{
	// 회의록 생성 백엔드 Worker.
	// 배포 전: `wrangler r2 bucket create kiba-meetings`, `wrangler secret put MEETING_PASSWORD`
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "kiba-meeting-summarize",
	"main": "src/index.ts",
	"compatibility_date": "2025-06-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"r2_buckets": [
		{
			"binding": "MEETINGS",
			"bucket_name": "kiba-meetings"
		},
		{
			"bucket_name": "kiba-mettings",
			"binding": "kiba_mettings",
			"remote": true
		}
	],
	"vars": {
		// 콤마로 구분된 허용 origin 목록. 프론트가 배포된 origin을 넣는다.
		"ALLOWED_ORIGINS": "https://playzzin.github.io",
		"STT_MODEL": "@cf/openai/whisper",
		"LLM_MODEL": "@cf/meta/llama-3.1-8b-instruct",
		"MAX_AUDIO_MB": "25",
		"MAX_TEXT_MB": "2"
	}
	// 비밀값: MEETING_PASSWORD 는 `wrangler secret put MEETING_PASSWORD` 로 설정한다.
}