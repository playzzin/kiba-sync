rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isStaff() {
      return userRole() in ['admin', 'manager', 'staff'];
    }

    function isSmallFile(maxMb) {
      return request.resource != null && request.resource.size < maxMb * 1024 * 1024;
    }

    match /users/{userId}/{allPaths=**} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId && isSmallFile(20);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /erp/{allPaths=**} {
      allow read: if isStaff();
      allow create, update: if isStaff() && isSmallFile(50);
      allow delete: if isStaff();
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
